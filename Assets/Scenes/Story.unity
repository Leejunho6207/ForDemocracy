--- !u!114 &1907849862
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1907849860}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "18\uC138\uAE30 \uB9D0, \uC99D\uAE30\uAE30\uAD00\uC758 \uAC70\uB300\uD55C
    \uD1B1\uB2C8\uBC14\uD034\uAC00 \uB9DE\uBB3C\uB824 \uB3CC\uC544\uAC00\uBA70\n\uACF5\uC7A5\uC758
    \uAD74\uB69D\uC5D0\uC11C\uB294 \uBC24\uB0AE\uC5C6\uC774 \uAC80\uC740 \uC5F0\uAE30\uAC00
    \uBFDC\uC5B4\uC838 \uB098\uC654\uB2E4.\n\uAE30\uACC4 \uBB38\uBA85\uC758 \uD3ED\uBC1C\uC801\uC778
    \uBC1C\uC804\uC740\n\uAD6D\uAC00\uC5D0 \uC720\uB840\uC5C6\uB294 \uD48D\uC694\uC640
    \uB9C9\uB300\uD55C \uBD80\uB97C \uAC00\uC838\uB2E4\uC8FC\uB294 \uB4EF\uD588\uB2E4.\n\n\uADF8\uB7EC\uB098
    \uADF8 \uD654\uB824\uD55C \uBC88\uC601\uC758 \uC774\uBA74\uC740 \uC794\uD639\uD588\uB2E4.\n\n\uC870\uB974\uC13C\uC758
    \uC808\uB300 \uAD8C\uB825\uC790, \uC655 \u2018\uC774\uC2E0\u2019\uC740\n\uAC15\uCCA0\uBCF4\uB2E4
    \uCC28\uAC00\uC6B4 \uB3C5\uC7AC \uC815\uCE58\uB85C \uAD6D\uAC00\uB97C \uC9C0\uBC30\uD558\uAE30
    \uC2DC\uC791\uD588\uB2E4.\n\uADF8\uB294 \uAE30\uACC4\uAC00 \uAC00\uC838\uB2E4\uC900
    \uCC9C\uBB38\uD559\uC801\uC778 \uBD80\uB97C \uC655\uAC00\uC640 \uC77C\uBD80 \uD2B9\uAD8C
    \uADC0\uC871\uB4E4\uC5D0\uAC8C\uB9CC \uB3C5\uC810\uC2DC\uCF30\uACE0,\n\uC790\uC2E0\uC758
    \uAD8C\uB825\uC744 \uACF5\uACE0\uD788 \uD558\uAE30 \uC704\uD574 \uBE44\uBC00\uACBD\uCC30\uACFC
    \uAD70\uB300\uB97C \uB3D9\uC6D0\uD574 \uBBFC\uC911\uC758 \uBAA9\uC744 \uC8C4\uC5B4\uC654\uB2E4.\n\n\uC655\uC758
    \uD0D0\uC695\uC2A4\uB7EC\uC6B4 \uB3C5\uC815\uC5D0 \uC2E0\uC74C\uD558\uB294 \uAC83\uC740
    \uC5B8\uC81C\uB098 \uD3C9\uBC94\uD55C \uAD6D\uBBFC\uB4E4\uC774\uC5C8\uB2E4.\n\n\uD558\uB8E8
    16\uC2DC\uAC04\uC774 \uB118\uB294 \uAC00\uD639\uD55C \uB178\uB3D9,\n\uAE30\uACC4\uC5D0
    \uC9D3\uACA8 \uB098\uAC00\uB3C4 \uCE58\uB8CC\uBC1B\uC9C0 \uBABB\uD558\uB294 \uBE44\uCC38\uD55C
    \uD604\uC2E4,\n\uADF8\uB9AC\uACE0 \uB9E4\uC77C\uAC19\uC774 \uB298\uC5B4\uAC00\uB294
    \uC794\uC778\uD55C \uC138\uAE08 \uD3ED\uD0C4 \uC18D\uC5D0\uC11C\n\uC870\uB974\uC13C\uC758
    \uBE48\uBBFC\uCE35\uACFC \uB178\uB3D9\uC790\uB4E4\uC740 \uC11C\uC11C\uD788 \uAD76\uC5B4
    \uC8FD\uC5B4\uAC14\uB2E4.\n\uB3C4\uC2DC\uB294 \uB9E4\uC5F0\uACFC \uC808\uB9DD\uC73C\uB85C
    \uAC00\uB4DD \uCC3C\uACE0, \uAC70\uB9AC\uB294 \uC2DC\uCCB4\uC640 \uBD80\uB791\uC790\uB85C
    \uB118\uCCD0\uB0AC\uB2E4.\n\n\uC790\uBE44 \uC5C6\uB294 \uCCA0\uD608\uC758 \uAD70\uC8FC
    \uC774\uC2E0\uC740\n\uC790\uC2E0\uC5D0\uAC8C \uB300\uD56D\uD558\uB294 \uBAA8\uB4E0
    \uBAA9\uC18C\uB9AC\uB97C '\uBC18\uC5ED'\uC73C\uB85C \uADDC\uC815\uD558\uACE0
    \uB2E8\uB450\uB300\uB85C \uBCF4\uB0C8\uB2E4.\n\uC228\uC870\uCC28 \uC274 \uC218
    \uC5C6\uB294 \uC554\uD751\uC758 \uC2DC\uB300\uC600\uB2E4.\n\n\uD558\uC9C0\uB9CC
    \uC5B5\uC555\uC774 \uADF9\uC5D0 \uB2EC\uD588\uC744 \uB54C, \uAC00\uC7A5 \uB0AE\uC740
    \uACF3\uC5D0\uC11C \uBCC0\uD654\uC758 \uC6C0\uC9C1\uC784\uC774 \uC2DC\uC791\uB418\uC5C8\uB2E4.\n\n\uB354
    \uC774\uC0C1 \uAD76\uC5B4 \uC8FD\uC744 \uC218 \uC5C6\uC5C8\uB358 \uC774\uB4E4,\n\uADF8\uB9AC\uACE0
    \uC655\uC758 \uBAA9\uC744 \uBCA0\uACE0 \uBBFC\uC8FC\uC8FC\uC758\uB77C\uB294 \uC0C8\uB85C\uC6B4
    \uC0C8\uBCBD\uC744 \uAFC8\uAFB8\uB294 \uC774\uB4E4\uC774\n\uC5B4\uB450\uC6B4
    \uC9C0\uD558 \uBC00\uC2E4\uB85C \uBAA8\uC5EC\uB4E4\uC5C8\uB2E4.\n\uADF8\uB4E4\uC740
    \uC2A4\uC2A4\uB85C\uB97C \uD601\uBA85\uC758 \uBD88\uAF43, \u201C\uCF54\uB974\uB514\uC544
    \uB808\uC9C0\uC2A4\uD0D5\uC2A4\u201D\uB77C \uBD88\uB800\uB2E4.\n\n\uC774\uB4E4\uC740
    \uC5B5\uC555\uBC1B\uB294 \uC870\uB974\uC13C \uAD6D\uBBFC\uB4E4\uC758 \uBD84\uB178\uB97C
    \uBAA8\uC544\n\uC655\uC815\uC744 \uBB34\uB108\uB728\uB9AC\uACE0 \uBAA8\uB4E0
    \uAD8C\uB825\uC744 \uC2DC\uBBFC\uC5D0\uAC8C \uB3CC\uB824\uC8FC\uAE30 \uC704\uD55C
    \uACA9\uB82C\uD55C \uD3ED\uB3D9\uC744 \uC900\uBE44\uD55C\uB2E4.\n\n\uC774\uC5D0
    \uB9DE\uC11C, \uC655 \u2018\uC774\uC2E0\u2019\uC758 \uC808\uB300\uC801\uC778
    \uBA85\uB839 \uC544\uB798\n\uC81C\uAD6D\uC758 \uC9C8\uC11C\uB97C \uC720\uC9C0\uD558\uACE0
    \uD601\uBA85\uC758 \uC2F9\uC744 \uBB34\uC790\uBE44\uD558\uAC8C \uC9D3\uBC1F\uC73C\uB824\uB294\n\uAD6D\uAC00
    \uCE5C\uC704\uB300 \u201C\uC870\uB974\uC13C \uAC00\uB514\uC5B8\uC988\u201D\uAC00
    \uCD1D\uCE7C\uC744 \uACA8\uB204\uBA70 \uCD9C\uACA9\uD55C\uB2E4.\n\n\uCCA0\uACFC
    \uC99D\uAE30\uC758 \uBE44\uB9B0\uB0B4 \uB098\uB294 \uB3C4\uC2DC,\n\uC655\uAC00\uB97C
    \uC218\uD638\uD558\uB824\uB294 \uC790\uB4E4\uACFC, \uC2DC\uB300\uC758 \uC8FC\uC778\uC774
    \uB418\uB824\uB294 \uC790\uB4E4.\n\n\uB450 \uAC70\uB300\uD55C \uC6B4\uBA85\uC758
    \uBCF8\uACA9\uC801\uC778 \uCDA9\uB3CC\uC774, \uC9C0\uAE08 \uC2DC\uC791\uB41C\uB2E4."
  m_isRightToLeft: 0
